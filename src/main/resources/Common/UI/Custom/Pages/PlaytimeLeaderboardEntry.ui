$C = "../Common.ui";
$S = "../styles.ui";
Group {
  Anchor: (Bottom: 5);

  Group #EntryBg {
    LayoutMode: Left;
    Background: (Color: #1a2a3a);
    Padding: (Top: 4, Bottom: 4);
    Anchor: (Full: 0);

    Group {
      LayoutMode: Top;
      FlexWeight: 1;

      Group {
        LayoutMode: Left;

        Label #Rank {
          Style: (
            FontSize: 12,
            RenderBold: true,
            TextColor: #ffffff
          );
          Anchor: (Left: 10, Top: 4, Bottom: 2);
          Padding: (Left: 6, Right: 6, Top: 2, Bottom: 2);

          Background: (Color: #1a3a4a);

          OutlineColor: #00AAAA;
          OutlineSize: 1.5;
        }

        Label #Time {
          Style: (
            FontSize: 14,
            RenderBold: true,
            TextColor: #FFD700
          );
          Anchor: (Left: 10, Top: 2);
          Padding: (Right: 5);
        }
      }

      Label #Name {
        Style: (
          FontSize: 14,
          RenderBold: false,
          TextColor: #ffffff,
          Wrap: true
        );
        Anchor: (Left: 10);
        Padding: (Right: 5);
        Overscroll: true;
      }
    }
  }
}
